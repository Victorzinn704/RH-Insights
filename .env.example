# Firebase Configuration
# Get these from Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_FIRESTORE_DATABASE_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Functions URL
# After deploying functions, get the URL from Firebase Console > Functions
# For local development, use: http://127.0.0.1:5001/{project-id}/{region}/aiProxy
VITE_FUNCTIONS_URL=

# Firebase App Check — reCAPTCHA v3 Site Key
# Get from https://www.google.com/recaptcha/admin/create
# Required for App Check to work in production
VITE_RECAPTCHA_SITE_KEY=

# DEPRECATED: VITE_GEMINI_API_KEY
# Gemini API key is now managed server-side via Firebase Functions config.
# Do NOT set this in production. Only for local emulator testing if needed.
# VITE_GEMINI_API_KEY=

# Sentry DSN for Error Tracking
# Get from https://sentry.io/settings/projects/your-project/keys/
VITE_SENTRY_DSN=
